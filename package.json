{
  "name": "financial-tracker-sea",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "next-themes": "^0.4.6",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:desktop": "turbo -F desktop dev:hmr",
    "build:desktop": "turbo -F desktop build:stable",
    "build:desktop:canary": "turbo -F desktop build:canary",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @financial-tracker-sea/db db:push",
    "db:studio": "turbo -F @financial-tracker-sea/db db:studio",
    "db:generate": "turbo -F @financial-tracker-sea/db db:generate",
    "db:migrate": "turbo -F @financial-tracker-sea/db db:migrate",
    "db:local": "turbo -F @financial-tracker-sea/db db:local",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@financial-tracker-sea/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@financial-tracker-sea/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "^2.0.13",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.11"
}
