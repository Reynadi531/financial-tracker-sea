{
  "mcpServers": {
    "figma": {
      "url": "http://127.0.0.1:3845/mcp",
      "type": "http",
      "directTools": true
    },
    "better-t-stack": {
      "command": "bunx",
      "args": [
        "create-better-t-stack@latest",
        "mcp"
      ],
      "directTools": true
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "directTools": true
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "-y",
        "shadcn@latest",
        "mcp"
      ],
      "directTools": true
    }
  }
}
