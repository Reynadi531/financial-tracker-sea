# Server environment variables

# SQLite database URL (libsql compatible)
# For local file-based SQLite: file:../../local.db
# For Turso remote database: libsql://your-db.turso.io
DATABASE_URL=file:../../local.db

# CORS origin — must match the web app URL
CORS_ORIGIN=http://localhost:3001

# Node environment (development | production | test)
NODE_ENV=development
